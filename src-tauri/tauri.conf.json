{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OctiqFlow",
  "version": "0.1.0",
  "identifier": "com.kyson.octiq-flow",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OctiqFlow",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 640,
        "maximized": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["/**", "**"]
      }
    }
  },
  "plugins": {
    "macos-fps": {
      "enabled": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
